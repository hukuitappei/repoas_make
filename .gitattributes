# ===========================
# Unity YAML テキストアセット — クロスプラットフォーム LF 統一
# ===========================
*.cs            text eol=lf
*.shader        text eol=lf
*.cginc         text eol=lf
*.hlsl          text eol=lf
*.glsl          text eol=lf
*.compute       text eol=lf
*.meta          text merge=unityyamlmerge eol=lf
*.unity         text merge=unityyamlmerge eol=lf
*.prefab        text merge=unityyamlmerge eol=lf
*.asset         text merge=unityyamlmerge eol=lf
*.mat           text merge=unityyamlmerge eol=lf
*.anim          text merge=unityyamlmerge eol=lf
*.controller    text merge=unityyamlmerge eol=lf
*.overrideController text merge=unityyamlmerge eol=lf
*.playable      text merge=unityyamlmerge eol=lf
*.mask          text merge=unityyamlmerge eol=lf
*.brush         text merge=unityyamlmerge eol=lf
*.flare         text merge=unityyamlmerge eol=lf
*.fontsettings  text merge=unityyamlmerge eol=lf
*.guiskin       text merge=unityyamlmerge eol=lf
*.lighting      text merge=unityyamlmerge eol=lf
*.renderTexture text merge=unityyamlmerge eol=lf
*.spriteatlas   text merge=unityyamlmerge eol=lf
*.terrainlayer  text merge=unityyamlmerge eol=lf
*.mixer         text merge=unityyamlmerge eol=lf
*.signal        text merge=unityyamlmerge eol=lf

# ===========================
# ドキュメント / テキスト
# ===========================
*.md            text eol=lf
*.txt           text eol=lf
*.json          text eol=lf
*.xml           text eol=lf
*.csv           text eol=lf

# ===========================
# Git LFS — スプライト / テクスチャ
# ===========================
*.png           filter=lfs diff=lfs merge=lfs -text
*.jpg           filter=lfs diff=lfs merge=lfs -text
*.jpeg          filter=lfs diff=lfs merge=lfs -text
*.tga           filter=lfs diff=lfs merge=lfs -text
*.psd           filter=lfs diff=lfs merge=lfs -text
*.tiff          filter=lfs diff=lfs merge=lfs -text
*.bmp           filter=lfs diff=lfs merge=lfs -text
*.gif           filter=lfs diff=lfs merge=lfs -text
*.svg           filter=lfs diff=lfs merge=lfs -text
*.webp          filter=lfs diff=lfs merge=lfs -text

# ===========================
# Git LFS — 音声
# ===========================
*.wav           filter=lfs diff=lfs merge=lfs -text
*.mp3           filter=lfs diff=lfs merge=lfs -text
*.ogg           filter=lfs diff=lfs merge=lfs -text
*.aiff          filter=lfs diff=lfs merge=lfs -text
*.flac          filter=lfs diff=lfs merge=lfs -text
*.aif           filter=lfs diff=lfs merge=lfs -text

# ===========================
# Git LFS — 3D / アニメーション
# ===========================
*.fbx           filter=lfs diff=lfs merge=lfs -text
*.obj           filter=lfs diff=lfs merge=lfs -text
*.blend         filter=lfs diff=lfs merge=lfs -text
*.dae           filter=lfs diff=lfs merge=lfs -text
*.3ds           filter=lfs diff=lfs merge=lfs -text

# ===========================
# Git LFS — 動画
# ===========================
*.mp4           filter=lfs diff=lfs merge=lfs -text
*.mov           filter=lfs diff=lfs merge=lfs -text
*.webm          filter=lfs diff=lfs merge=lfs -text

# ===========================
# Git LFS — Unity パッケージ / コンパイル済みバイナリ
# ===========================
*.unitypackage  filter=lfs diff=lfs merge=lfs -text
*.dll           filter=lfs diff=lfs merge=lfs -text

# ===========================
# バイナリ（LFS なし）
# ===========================
*.zip           binary
*.tar.gz        binary
*.7z            binary
